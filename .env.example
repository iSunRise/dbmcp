# Port on the HOST that maps to the container's port 3991.
HOST_PORT=3991

# Named databases. Callers select one by name (case-insensitive): the part
# between DB_ and _URL. Each may live on a different host with different
# credentials — all kept server-side, never exposed to callers.
#   DB_DEVDB_URL   -> caller uses "devDb"
#   DB_STAGEDB_URL -> caller uses "stageDb"
DB_DEVDB_URL=postgres://devuser:devpass@devdb:5432/dev
DB_STAGEDB_URL=postgres://stageuser:stagepass@stagedb:5432/stage
# Add as many as you like:
# DB_PRODDB_URL=postgres://readonly:secret@prod-host.internal:5432/app
#
# Optionally set an unnamed default used when the caller omits `database`:
# DATABASE_URL=postgres://devuser:devpass@devdb:5432/dev

# Hard query timeout (ms).
QUERY_TIMEOUT_MS=30000

# Inline preview limits.
MAX_OUTPUT_CHARS=1000
MAX_CELL_CHARS=100

# Base URL callers use to fetch exported CSVs. Must match HOST_PORT.
# - Host callers:      http://localhost:3991
# - Container callers: http://host.docker.internal:3991  (so the CSV links
#   resolve to the host's mapped port, not the calling container itself)
PUBLIC_BASE_URL=http://localhost:3991

# Interface to bind to inside the container. 0.0.0.0 (default) makes the mapped
# port reachable from the host and from other containers via host.docker.internal.
# BIND_HOST=0.0.0.0

# Optional bearer token. When set, every /mcp request must send
# `Authorization: Bearer <token>`. Leave empty to disable auth.
MCP_AUTH_TOKEN=

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
