# Port on the HOST that maps to the container's port 3000.
HOST_PORT=3000

# PostgreSQL connection string used by the server (kept server-side only).
# When using the bundled `db` service, the default below works as-is.
DATABASE_URL=postgres://app:app@db:5432/app

# Hard query timeout (ms).
QUERY_TIMEOUT_MS=30000

# Inline preview limits.
MAX_OUTPUT_CHARS=1000
MAX_CELL_CHARS=100

# Base URL callers use to fetch exported CSVs. Must match HOST_PORT.
PUBLIC_BASE_URL=http://localhost:3000

# Host port for the bundled Postgres (only relevant if you use the `db` service).
DB_HOST_PORT=5432
